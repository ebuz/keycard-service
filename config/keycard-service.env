# Environment overrides for keycard-service
# Copy this to /etc/default/keycard-service and set values as needed.

# Wild Apricot API credentials (JSON file path)
# WILDA_CREDENTIALS="/etc/keycard-service/credentials/wild-apricot.json"

# Google Sheets API credentials (JSON file path)
# GOOGLE_CREDENTIALS="/etc/keycard-service/credentials/google.json"

# Google Sheets URL for reports
# SPREADSHEET="https://docs.google.com/spreadsheets/d/1V2NxKgbt-xdNdx4_qWHwJsW54gU7jEIdkN_h0iREqkU"

# GRL rules source. Leave empty to use the repo-bundled default rules.
# Set to a public URL to override at runtime.
# RULES_URL=""

# Telemetry: set to 1 to enable the optional telemetry gatherer
# KEYCARD_TELEMETRY=0

# Alerting
# DISCORD_ALERT_WEBHOOK=""
# ALERT_EMAIL=""
