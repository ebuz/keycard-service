#!/bin/bash
set -euo pipefail

# Keycard Service: Alert helper
# Sends alerts via Discord or email when a systemd unit fails.
# Called by keycard-alert-handler@<unit>.service.

DISCORD_ALERT_WEBHOOK="${DISCORD_ALERT_WEBHOOK:-}"
DISCORD_ALERT_CHANNEL="${DISCORD_ALERT_CHANNEL:-}"
ALERT_EMAIL="${ALERT_EMAIL:-}"

SERVICE_NAME="${1:-unknown}"

# Get the most recent failure details from journald
# (last 20 lines of the failed service)
FAILURE_DETAILS=""
if command -v journalctl >/dev/null 2>&1; then
    FAILURE_DETAILS="$(journalctl -u "${SERVICE_NAME}" -n 20 --no-pager --output=short-iso 2>/dev/null || true)"
fi

MESSAGE="Service ${SERVICE_NAME} failed.

Recent journal entries:
${FAILURE_DETAILS}"

send_discord() {
    local msg="$1"
    if [ -n "${DISCORD_ALERT_WEBHOOK}" ]; then
        # Truncate to Discord's 2000 char limit if needed
        if [ "${#msg}" -gt 1900 ]; then
            msg="${msg:0:1900}... (truncated)"
        fi
        curl -s -X POST \
            -H "Content-Type: application/json" \
            -d "{\"content\":\"[keycard-service] ${msg}\"}" \
            "${DISCORD_ALERT_WEBHOOK}" > /dev/null || true
    fi
}

send_email() {
    local msg="$1"
    if [ -n "${ALERT_EMAIL}" ] && command -v mail >/dev/null 2>&1; then
        echo "${msg}" | mail -s "[keycard-service] Alert: ${SERVICE_NAME}" "${ALERT_EMAIL}" || true
    fi
}

# Attempt Discord webhook alert
send_discord "${MESSAGE}"

# Attempt email alert
send_email "${MESSAGE}"

# Also try Python Discord bot integration if available
if [ -f /opt/keycard-service/scripts/discord_alert.py ] && [ -n "${DISCORD_BOT_TOKEN:-}" ]; then
    python3 /opt/keycard-service/scripts/discord_alert.py "${SERVICE_NAME}" "failed" "${MESSAGE}" 2>/dev/null || true
fi

echo "Alert dispatched for ${SERVICE_NAME}"
