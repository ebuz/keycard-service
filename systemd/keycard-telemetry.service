[Unit]
Description=Keycard Service: Gather telemetry (optional)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=keycard
Group=keycard
WorkingDirectory=/opt/keycard-service
EnvironmentFile=-/etc/default/keycard-service
ExecStart=/opt/keycard-service/scripts/telemetry
StandardOutput=journal
StandardError=journal
ConditionEnvironment=KEYCARD_TELEMETRY=1
OnFailure=keycard-alert-handler@%n.service

[Install]
WantedBy=multi-user.target
